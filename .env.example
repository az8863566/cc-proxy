# ─── 通用 ──────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
ANTHROPIC_AUTH_TOKEN=
LOG_LEVEL=info

# ─── 三级路由映射 ─────────────────────────────────────
# 格式: {provider}/{model}
# provider   → deepseek / zhipu / opencode_go
# / 后的值 → 实际发送给上游的模型名
MODEL_OPUS=opencode_go/glm-5.2
MODEL_SONNET=deepseek/deepseek-v4-pro
MODEL_HAIKU=opencode_go/deepseek-v4-flash

# Per-tier 温度（可选）
MODEL_OPUS_TEMPERATURE=0.2
MODEL_SONNET_TEMPERATURE=0.1
MODEL_HAIKU_TEMPERATURE=0.1

# Per-tier 思考方式: off / low / high / max（可选）
MODEL_OPUS_THINKING=max
MODEL_SONNET_THINKING=high
MODEL_HAIKU_THINKING=high

# ─── DeepSeek ───────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# ─── Zhipu GLM ─────────────────────────────────────
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ─── OpenCode Go ────────────────────────────────────
OPENCODE_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
