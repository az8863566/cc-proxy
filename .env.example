# ============ 代理服务 ============
PORT=8082
HOST=0.0.0.0
ANTHROPIC_AUTH_TOKEN=
LOG_LEVEL=info

# ============ DeepSeek (Anthropic 原生透传) ============
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro

# ============ 智谱 GLM (OpenAI 转换) ============
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_DEFAULT_MODEL=glm-5.2

# ============ OpenCode Go (OpenAI 转换) ============
OPENCODE_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_DEFAULT_MODEL=opencode/gpt-5.5

# ============ 默认路由 ============
DEFAULT_PROVIDER=deepseek
DEFAULT_MODEL=deepseek-v4-pro

# 按 Claude 模型分级映射 (格式: provider/model)
# 支持的 provider 前缀: deepseek, zhipu, glm, opencode_go, opencode
# 不带 "/" 则走 DEFAULT_PROVIDER
# 例: MODEL_OPUS=zhipu/GLM-5.2    → zhipu provider + GLM-5.2
# 例: MODEL_SONNET=deepseek/deepseek-v4-pro  → deepseek provider + ds v4 pro
# 例: MODEL_HAIKU=deepseek-v4-flash  → DEFAULT_PROVIDER + deepseek-v4-flash
MODEL_OPUS=
MODEL_SONNET=
MODEL_HAIKU=

# ============ Thinking 配置 ============
ENABLE_THINKING=true
THINKING_LEVEL=high
DEEPSEEK_THINKING_LEVEL=
ZHIPU_THINKING_LEVEL=
OPENCODE_GO_THINKING_LEVEL=

# ============ Temperature 配置 ============
TEMPERATURE=
DEEPSEEK_TEMPERATURE=
ZHIPU_TEMPERATURE=
OPENCODE_GO_TEMPERATURE=
