{
  "name": "cc-proxy",
  "version": "0.3.0",
  "private": true,
  "description": "Lightweight Claude Code multi-model proxy (DeepSeek, Zhipu GLM, OpenCode Go)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "stats": "node dist/stats-cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
